<div class="tab{{#if tab.active}} active{{/if}} sprite-shadows-config scrollable" {{#unless omitGroup}}data-group="shadows"{{/unless}} data-tab="blob" data-application-part="blob">
  <input type="hidden" name=".shape" value="circle" />

  <div class="form-group">
    <label for="{{idPrefix}}-color">{{localize
        "SPRITESHADOWS.SETTINGS.COLOR.LABEL"
      }}</label>
    <color-picker
      id="{{idPrefix}}-color"
      name="sprite-shadows.color"
      value="{{config.color}}"
    ></color-picker>
    <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.COLOR.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-alpha">{{localize
        "SPRITESHADOWS.SETTINGS.ALPHA.LABEL"
      }}</label>
    <range-picker
      id="{{idPrefix}}-alpha"
      name="sprite-shadows.alpha"
      value="{{config.alpha}}"
      min="0"
      max="1"
      step=".01"
    ></range-picker>
    <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ALPHA.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-blur">{{localize
        "SPRITESHADOWS.SETTINGS.BLUR.LABEL"
      }}</label>
    <input
      type="number"
      min="0"
      step="1"
      id="{{idPrefix}}-blur"
      name="sprite-shadows.blur"
      value="{{config.blur}}"
    />
    <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.BLUR.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-rotation">{{localize
        "SPRITESHADOWS.SETTINGS.ROTATION.LABEL"
      }}</label>
    <range-picker
      id="{{idPrefix}}-rotation"
      name="sprite-shadows.rotation"
      value="{{config.rotation}}"
      min="0"
      max="360"
      step="1"
    ></range-picker>
    <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ROTATION.HINT"}}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-adjustForElevation">{{localize
        "SPRITESHADOWS.SETTINGS.ELEVATIONADJUST.LABEL"
      }}</label>
    <input
      type="checkbox"
      id="{{idPrefix}}-adjustForElevation"
      name="sprite-shadows.adjustForElevation"
      {{checked config.adjustForElevation}}
    />

    <p class="hint">{{localize
        "SPRITESHADOWS.SETTINGS.ELEVATIONADJUST.HINT"
      }}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-elevationIncrement">{{localize
        "SPRITESHADOWS.SETTINGS.ELEVATIONINCREMENT.LABEL"
      }}</label>
    <input
      type="number"
      id="{{idPrefix}}-elevationIncrement"
      name="sprite-shadows.elevationIncrement"
      placeholder="0"
      step="any"
      value="{{config.elevationIncrement}}"
      min="0"
    />
    <p class="hint">{{localize
        "SPRITESHADOWS.SETTINGS.ELEVATIONINCREMENT.HINT"
      }}</p>
  </div>

  <div class="form-group">
    <label for="{{idPrefix}}-liftToken">{{localize
        "SPRITESHADOWS.SETTINGS.LIFTTOKEN.LABEL"
      }}</label>
    <input
      type="checkbox"
      id="{{idPrefix}}-liftToken"
      name="sprite-shadows.liftToken"
      {{checked config.liftToken}}
    />
    <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.LIFTTOKEN.HINT"}}</p>
  </div>

    <fieldset>
      <legend>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.LABEL"}}</legend>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.HINT"}}</p>

      {{#if ../spriteAnimations}}
        <div class="form-group">
          <label for="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments">{{localize "SPRITESHADOWS.SETTINGS.IGNORESAADJUSTMENTS.LABEL"}}</label>
          <input type="checkbox" id="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments" name="sprite-shadows.ignoreSpriteAnimationsMeshAdjustments" {{checked config.ignoreSpriteAnimationsMeshAdjustments}}>
          <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.IGNORESAADJUSTMENTS.HINT"}}</p>
        </div>
      {{else}}
        <input type="hidden" id="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments" name="ignoreSpriteAnimationsMeshAdjustments" value="true">
      {{/if}}

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.POSITION"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsX">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.X"}}</label>
          <input type="number" step="any" value="{{config.adjustments.x}}" name="sprite-shadows.adjustments.x" data-role="shadow-adjustment">

          <label for="{{idPrefix}}-adjustmentsY">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.Y"}}</label>
          <input type="number" step="any" value="{{config.adjustments.y}}" name="sprite-shadows.adjustments.y" data-role="shadow-adjustment">
          
          <button type="button" data-role="shadow-drag-pos" data-tooltip="{{{adjustPosTooltip}}}"><i class="fa-solid fa-up-down-left-right"></i></button>
        </div>
      </div>

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.SIZE"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsWidth">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.WIDTH"}}</label>
          <input type="number" step="any" value="{{config.adjustments.width}}" name="sprite-shadows.adjustments.width" id="{{idPrefix}}-adjustmentsWidth">

          <label for="{{idPrefix}}-adjustmentsHeight">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.HEIGHT"}}</label>
          <input type="number" step="any" value="{{config.adjustments.height}}" name="sprite-shadows.adjustments.height" id="{{idPrefix}}-adjustmentsHeight">

          <button type="button" data-role="shadow-drag-size" data-tooltip="{{{adjustSizeTooltip}}}"><i class="fa-solid fa-up-down-left-right"></i></button>
        </div>
      </div>

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.ANCHOR"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsAnchorX">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.X"}}</label>
          <input type="number" step="any" min="0" max="1" value="{{config.adjustments.anchor.x}}" name="sprite-shadows.adjustments.anchor.x" id="{{idPrefix}}-adjustmentsAnchorX">

          <label for="{{idPrefix}}-adjustmentsAnchorY">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.Y"}}</label>
          <input type="number" step="any" min="0" max="1" value="{{config.adjustments.anchor.y}}" name="sprite-shadows.adjustments.anchor.y" id="{{idPrefix}}-adjustmentsAnchorY">

          <button type="button" data-role="auto-shadow-anchor" data-action="autoSetShadowAnchor" data-tooltip="{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.ANCHORTOOLTIP"}}">
            <i class="fa-solid fa-crosshairs"></i>
          </button>
        </div>
      </div>
    </fieldset>
</div>
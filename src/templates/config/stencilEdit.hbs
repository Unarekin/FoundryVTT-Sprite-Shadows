<section>
  {{#with shadow}}
    <input type="hidden" name="id" value="{{id}}">
    <div class="form-group">
      <label for="{{idPrefix}}-enabled">{{localize
          "SPRITESHADOWS.SETTINGS.ENABLE.LABEL"
        }}</label>
      <input
        type="checkbox"
        id="{{idPrefix}}-enabled"
        name="enabled"
        {{checked enabled}}
      />
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ENABLE.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-color">{{localize
          "SPRITESHADOWS.SETTINGS.COLOR.LABEL"
        }}</label>
      <color-picker
        id="{{idPrefix}}-color"
        name="color"
        value="{{color}}"
      ></color-picker>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.COLOR.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-alpha">{{localize
          "SPRITESHADOWS.SETTINGS.ALPHA.LABEL"
        }}</label>
      <range-picker
        id="{{idPrefix}}-alpha"
        name="alpha"
        value="{{alpha}}"
        min="0"
        max="1"
        step=".01"
      ></range-picker>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ALPHA.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-blur">{{localize
          "SPRITESHADOWS.SETTINGS.BLUR.LABEL"
        }}</label>
      <input
        type="number"
        min="0"
        step="1"
        id="{{idPrefix}}-blur"
        name="blur"
        value="{{blur}}"
      />
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.BLUR.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-rotation">{{localize
          "SPRITESHADOWS.SETTINGS.ROTATION.LABEL"
        }}</label>
      <range-picker
        id="{{idPrefix}}-rotation"
        name="rotation"
        value="{{rotation}}"
        min="0"
        max="360"
        step="1"
      ></range-picker>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ROTATION.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-skew">{{localize
          "SPRITESHADOWS.SETTINGS.SKEW.LABEL"
        }}</label>
      <range-picker
        id="{{idPrefix}}-skew"
        name="skew"
        step="any"
        placeholder="0"
        min="0"
        max="360"
        value="{{skew}}"
      ></range-picker>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.SKEW.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-alignment">{{localize
          "SPRITESHADOWS.SETTINGS.ALIGNMENT.LABEL"
        }}</label>
      <select id="{{idPrefix}}-alignment" name="alignment">
        {{selectOptions ../alignmentSelect selected=alignment localize=true}}
      </select>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ALIGNMENT.HINT"}}</p>
    </div>

    <div class="form-group">
      <label for="{{idPrefix}}-useImage">{{localize
          "SPRITESHADOWS.SETTINGS.USEIMAGE.LABEL"
        }}</label>
      <input
        type="checkbox"
        id="{{idPrefix}}-useImage"
        name="useImage"
        {{checked useImage}}
      />
      <p class="hint">{{{localize "SPRITESHADOWS.SETTINGS.USEIMAGE.HINT"}}}</p>
    </div>

    <div
      class="form-group"
      data-role="stencil-image-config"
      style="display:none"
    >
      <label for="{{idPrefix}}-image">{{localize
          "SPRITESHADOWS.SETTINGS.STENCILIMAGE.LABEL"
        }}</label>
      <file-picker
        type="image/video"
        id="{{idPrefix}}-image"
        name="image"
        value="{{image}}"
      ></file-picker>
      <p class="hint">{{localize
          "SPRITESHADOWS.SETTINGS.STENCILIMAGE.HINT"
        }}</p>
    </div>

    <fieldset>
      <legend>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.LABEL"}}</legend>
      <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.HINT"}}</p>

      {{#if ../spriteAnimations}}
        <div class="form-group">
          <label for="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments">{{localize "SPRITESHADOWS.SETTINGS.IGNORESAADJUSTMENTS.LABEL"}}</label>
          <input type="checkbox" id="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments" name="ignoreSpriteAnimationsMeshAdjustments" {{checked ignoreSpriteAnimationsMeshAdjustments}}>
          <p class="hint">{{localize "SPRITESHADOWS.SETTINGS.IGNORESAADJUSTMENTS.HINT"}}</p>
        </div>
      {{else}}
        <input type="hidden" id="{{idPrefix}}-ignoreSpriteAnimationsMeshAdjustments" name="ignoreSpriteAnimationsMeshAdjustments" value="true">
      {{/if}}

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.POSITION"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsX">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.X"}}</label>
          <input type="number" step="any" value="{{adjustments.x}}" name="adjustments.x" data-role="shadow-adjustment">

          <label for="{{idPrefix}}-adjustmentsY">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.Y"}}</label>
          <input type="number" step="any" value="{{adjustments.y}}" name="adjustments.y" data-role="shadow-adjustment">
          
          <button type="button" data-role="shadow-drag-pos" data-tooltip="{{{../adjustPosTooltip}}}"><i class="fa-solid fa-up-down-left-right"></i></button>
        </div>
      </div>

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.SIZE"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsWidth">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.WIDTH"}}</label>
          <input type="number" step="any" min="0" value="{{adjustments.width}}" name="adjustments.width" id="{{idPrefix}}-adjustmentsWidth">

          <label for="{{idPrefix}}-adjustmentsHeight">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.HEIGHT"}}</label>
          <input type="number" step="any" min="0" value="{{adjustments.height}}" name="adjustments.height" id="{{idPrefix}}-adjustmentsHeight">

          <button type="button" data-role="shadow-drag-size" data-tooltip="{{{../adjustSizeTooltip}}}"><i class="fa-solid fa-up-down-left-right"></i></button>
        </div>
      </div>

      <div class="form-group slim">
        <label>{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.ANCHOR"}}</label>
        <div class="form-fields">
          <label for="{{idPrefix}}-adjustmentsAnchorX">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.X"}}</label>
          <input type="number" step="any" min="0" max="1" value="{{adjustments.anchor.x}}" name="adjustments.anchor.x" id="{{idPrefix}}-adjustmentsAnchorX">

          <label for="{{idPrefix}}-adjustmentsAnchorY">{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.Y"}}</label>
          <input type="number" step="any" min="0" max="1" value="{{adjustments.anchor.y}}" name="adjustments.anchor.y" id="{{idPrefix}}-adjustmentsAnchorY">

          <button type="button" data-role="auto-shadow-anchor" data-action="autoSetShadowAnchor" data-tooltip="{{localize "SPRITESHADOWS.SETTINGS.ADJUSTMENTS.ANCHORTOOLTIP"}}">
            <i class="fa-solid fa-crosshairs"></i>
          </button>
        </div>
      </div>
    </fieldset>
  {{/with}}
</section>